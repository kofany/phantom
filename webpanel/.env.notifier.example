# Phantom Telegram notifier example config.
# Copy to `.env.notifier`, fill the values, chmod 600.
# Read by `notifier.ts` (run via `bun run notifier`).
#
# DO NOT commit the filled-in version — the bot token grants posting rights
# to anyone who reads it.

# ─── Hub TCP WebAPI connection ───────────────────────────────────────────
# Where the hub's webapi listener is reachable from this host. If the
# notifier runs next to the hub binary, 127.0.0.1 is correct.
HUB_HOST=127.0.0.1
HUB_PORT=5555
HUB_SSL=false

# Service handle on the hub. Create with:
#   .+user tgnotifier
#   .chpass tgnotifier <strong-password>
#   .chattr tgnotifier +PN
#   .+addr tgnotifier 127.0.0.1
HUB_HANDLE=tgnotifier
HUB_PASSWORD=

# ─── Telegram Bot API ────────────────────────────────────────────────────
# From @BotFather after /newbot. Format: digits:base64-ish.
TELEGRAM_BOT_TOKEN=

# Group/channel chat id. For groups, this is a NEGATIVE number starting
# with -100…, fetched from
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# after sending one message in the group with the bot present as admin.
TELEGRAM_CHAT_ID=

# ─── Cosmetic ────────────────────────────────────────────────────────────
# Used to add an "Open panel" link below alerts. Optional - leave blank
# to omit the link.
PANEL_URL=https://panel.example.com
